#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
COMMAND="${1:-help}"
shift || true

case "$COMMAND" in
  blast)
    exec "$ROOT/scripts/foreman-blast.sh" "$@"
    ;;
  press)
    exec python3 "$ROOT/scripts/foreman-press.py" "$@"
    ;;
  tools)
    exec "$ROOT/scripts/foreman-tools.sh" "$@"
    ;;
  init)
    exec "$ROOT/scripts/foreman-init.sh" "$@"
    ;;
  module|modules)
    exec "$ROOT/scripts/foreman-module.sh" "$@"
    ;;
  issues)
    exec "$ROOT/scripts/foreman-issues.sh" "$@"
    ;;
  chat)
    exec "$ROOT/scripts/foreman-chat.sh" "$@"
    ;;
  run|runs)
    exec "$ROOT/scripts/foreman-run.sh" "$@"
    ;;
  update)
    exec "$ROOT/scripts/foreman-update.sh" "$@"
    ;;
  fleet|fleet-check)
    exec "$ROOT/scripts/fleet-check.sh" "$@"
    ;;
  lph|little-publishing-house)
    exec python3 "$ROOT/scripts/foreman-lph.py" "$@"
    ;;
  company)
    SUBCOMMAND="${1:-help}"
    shift || true
    case "$SUBCOMMAND" in
      lph|little-publishing-house)
        exec python3 "$ROOT/scripts/foreman-lph.py" "$@"
        ;;
      *)
        echo "Unknown company command: $SUBCOMMAND" >&2
        echo "Run: foreman lph --help" >&2
        exit 1
        ;;
    esac
    ;;
  help|-h|--help)
    cat <<'EOF'
Foreman CLI

Usage:
  foreman blast "<prompt>" [options]
  foreman init
  foreman chat
  foreman module [args]
  foreman tools [doctor|list|search|install|manifest]
  foreman issues
  foreman run <command> [args]
  foreman update
  foreman fleet
  foreman lph <command> [args]
  foreman company little-publishing-house <command> ...
  foreman press propose|validate|register|list|inspect [args]

Blast Options:
  --template <name>    Force a specific template
  --provider <name>    Force a specific provider
  --dir <path>         Output directory
  --deluxe             Run Deluxe loop instead of Lean
  --dry-run            Show what would fire without executing
EOF
    ;;
  *)
    echo "Unknown command: $COMMAND" >&2
    echo "Run: foreman --help" >&2
    exit 1
    ;;
esac