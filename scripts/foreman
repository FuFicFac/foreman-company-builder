#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
COMMAND="${1:-help}"
shift || true

case "$COMMAND" in
  press)
    exec python3 "$ROOT/scripts/foreman-press.py" "$@"
    ;;
  tools)
    exec "$ROOT/scripts/foreman-tools.sh" "$@"
    ;;
  init)
    exec "$ROOT/scripts/foreman-init.sh" "$@"
    ;;
  module|modules)
    exec "$ROOT/scripts/foreman-module.sh" "$@"
    ;;
  issues)
    exec "$ROOT/scripts/foreman-issues.sh" "$@"
    ;;
  chat)
    exec "$ROOT/scripts/foreman-chat.sh" "$@"
    ;;
  lph|little-publishing-house)
    exec python3 "$ROOT/scripts/foreman-lph.py" "$@"
    ;;
  company)
    SUBCOMMAND="${1:-help}"
    shift || true
    case "$SUBCOMMAND" in
      lph|little-publishing-house)
        exec python3 "$ROOT/scripts/foreman-lph.py" "$@"
        ;;
      *)
        echo "Unknown company command: $SUBCOMMAND" >&2
        echo "Run: foreman lph --help" >&2
        exit 1
        ;;
    esac
    ;;
  help|-h|--help)
    cat <<'EOF'
Foreman CLI

Usage:
  foreman lph new <project-dir> --title <title> --stage <stage> [--mode hermes|paperclip] [--goal <goal>]
  foreman lph doctor <project-dir>
  foreman lph heartbeat <project-dir>
  foreman company little-publishing-house <command> ...
  foreman press propose --id <tool-id> --name <name> --description <text> --binary <abs-path> --command-name <name>
  foreman press validate <manifest.json>
  foreman press register <manifest.json>
  foreman press list
  foreman press inspect <tool-id>
  foreman tools [doctor|list|search|install|manifest]
EOF
    ;;
  *)
    echo "Unknown command: $COMMAND" >&2
    echo "Run: foreman --help" >&2
    exit 1
    ;;
esac
