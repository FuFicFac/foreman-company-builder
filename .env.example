# Foreman Company Builder — Environment Variables
#
# Copy this file to .env and fill in your keys, or export them in your shell.
# foreman init will detect these automatically and save references to ~/.foreman/secrets.env
# NEVER commit your real .env file — it is gitignored.

# ── API Keys scanned by foreman init ──────────────────────────

# OpenAI (GPT-4o, GPT-5, o3) — good cheap/fast brain for orchestration
# Get one: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# xAI / Grok (Grok 3) — strong reasoning, good for planning
# Get one: https://console.x.ai
XAI_API_KEY=

# Google / Gemini (Gemini 2.5 Pro) — strong reasoning
# Get one: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Anthropic / Claude (Claude Sonnet, Opus) — expensive, best for judgment/inspection only
# Get one: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── Optional configuration ────────────────────────────────────

# Override the default config directory (default: ~/.foreman)
# FOREMAN_CONFIG_DIR=/custom/path

# Override the install directory (default: ~/.foreman, used by install.sh)
# FOREMAN_INSTALL_DIR=/custom/path