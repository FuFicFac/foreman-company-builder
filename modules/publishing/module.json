      "dub"
    ],
    "research": [
      "wikipedia",
      "company-goat"
    ],
    "operations": [
      "linear",
      "notion",
      "slack"
    ]
  },
  "heartbeat_policy": {
    "mode": "calm",
    "office_hours": {
      "timezone": "America/Los_Angeles",
      "days": ["Mon", "Tue", "Wed", "Thu", "Fri"],
      "start": "09:30",
      "end": "16:30"
    },
    "frequency": {
      "office_hours": "every 20m",
      "off_hours": "every 4h",
      "weekends": "daily at 10:00"
    },
    "interruptions": {
      "office_hours": ["normal", "urgent", "critical"],
      "off_hours": ["critical"]
    },
    "critical_examples": [
      "paid customer cannot access book file",
      "refund or payment failure",
      "public launch page down",
      "email campaign sending broken links",
      "private data exposure",
      "runaway spend or security incident"
    ],
    "digests": {
      "morning": true,
      "overnight": true
    }
  },
  "source": "built-in",
  "twelve_factor_profile": {
    "natural_language_to_structured_actions": true,
    "owned_prompts": true,
    "owned_context_packets": true,
    "tools_as_structured_outputs": true,
    "unified_execution_and_business_state": true,
    "pause_resume_runs": true,
    "human_decision_events": true,
    "owned_control_flow": true,
    "compact_failure_packets": true,
    "small_focused_role_agents": true,
    "trigger_from_anywhere": true,
    "stateless_reducer_loop": true
  },
  "stages": [
    "idea",
    "outline",
    "partial-draft",
    "finished-draft",
    "developmental-edit",
    "revision",
