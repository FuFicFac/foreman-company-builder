    },
    "publishing": {
      "relevance": "required",
      "notes": "Manuscript pipeline, editorial stages"
    },
    "education_community": {
      "relevance": "required",
      "notes": "Curriculum, lessons, assessments, cohort materials"
    }
  },
  "tool_manifest": {
    "product-delivery": [
      "linear",
      "github",
      "notion"
    ],
    "software-development": [
      "github"
    ],
    "editorial": [
      "storycraft"
    ],
    "launch-operations": [
      "notion",
      "calendar"
    ]
  },
  "recommended_capabilities": [
    "operations-sop",
    "quality-inspection",
    "launch-operations"
  ],
  "conditional_capabilities": {
    "software_company": [
      "software-development",
      "deployment"
    ],
    "publishing_company": [
