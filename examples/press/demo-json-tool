#!/usr/bin/env bash
set -euo pipefail

COMMAND="${1:-lookup}"
shift || true

CITY="Austin"
while [[ $# -gt 0 ]]; do
  case "$1" in
    --city)
      CITY="${2:-}"
      shift 2
      ;;
    *)
      echo '{"error":"usage","message":"unknown argument"}' >&2
      exit 2
      ;;
  esac
done

case "$COMMAND" in
  lookup)
    python3 - "$CITY" <<'PY'
import json, sys
city = sys.argv[1] or "Austin"
print(json.dumps({"city": city, "condition": "sunny", "source": "local-demo"}, sort_keys=True))
PY
    ;;
  *)
    echo '{"error":"usage","message":"unknown command"}' >&2
    exit 2
    ;;
esac
